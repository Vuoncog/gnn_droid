<?xml version="1.0" encoding="utf-8" standalone="no"?><manifest xmlns:android="http://schemas.android.com/apk/res/android" package="com.mangosoft.android.wallpapers">
    <uses-permission android:name="android.permission.READ_PHONE_STATE"/>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.READ_CONTACTS"/>
    <uses-permission android:name="android.permission.WRITE_CONTACTS"/>
    <uses-permission android:name="android.permission.SET_WALLPAPER"/>
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"/>
    <application android:debuggable="false" android:icon="@drawable/icon" android:label="@string/app_name">
        <activity android:label="@string/app_name" android:name=".HomeActivity" android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <activity android:label="分类" android:name=".CategoriesActivity" android:screenOrientation="portrait"/>
        <activity android:label="我的下载" android:name=".DownloadsActivity" android:screenOrientation="portrait"/>
        <activity android:label="浏览壁纸" android:name=".ImageListActivity" android:screenOrientation="portrait"/>
        <activity android:label="壁纸" android:name=".SingleImageViewActivity" android:screenOrientation="portrait"/>
        <activity android:label="分享" android:name=".ShareDialog" android:theme="@android:style/Theme.Dialog"/>
        <activity android:label="随机浏览" android:name=".RandomWallpapersActivity" android:screenOrientation="portrait"/>
        <activity android:label="Flickr Search" android:name=".SearchImageActivity" android:screenOrientation="portrait"/>
        <activity android:label="联系人列表" android:name=".ContactsListActivity" android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.VIEW"/>
                <action android:name="android.intent.action.PICK"/>
                <category android:name="android.intent.category.DEFAULT"/>
            </intent-filter>
        </activity>
        <activity android:label="自动切换" android:name=".SettingsActivity"/>
        <receiver android:name=".service.StartupReceiver">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED"/>
            </intent-filter>
            <intent-filter>
                <action android:name="com.awesomewp.ROTATE_SERVICE"/>
            </intent-filter>
        </receiver>
        <receiver android:name=".service.RotateWallpaperReceiver"/>
        <service android:name=".service.RotateWallpaperService"/>
        <activity android:configChanges="keyboard|keyboardHidden|orientation" android:name="net.youmi.android.AdActivity"/>
    </application>
</manifest>