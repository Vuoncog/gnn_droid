# - return:int

a-BB@0x0 : 
	0       (00000000) iget                 v0, v2, Lcom/a/a/d/c/k;->f I
	1       (00000004) iget                 v1, v2, Lcom/a/a/d/c/k;->i I
	2       (00000008) div-int/2addr        v0, v1
	3       (0000000a) return               v0

