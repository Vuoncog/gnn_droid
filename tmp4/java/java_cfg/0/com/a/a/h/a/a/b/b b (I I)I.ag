# Lcom/a/a/h/a/a/b;->b(I I)I [access_flags=]
#
# Parameters:
# - local registers: v0...v2
# - v3:int
# - v4:int
#
# - return:int

b-BB@0x0 : 
	0       (00000000) add-int              v0, v3, v4
	1       (00000004) iget                 v1, v2, Lcom/a/a/h/a/a/b;->f I
	2       (00000008) rem-int/2addr        v0, v1
	3       (0000000a) return               v0

