a-BB@0x0 : [ a-BB@0x4 ]
	0       (00000000) const/4              v0, 0
	1       (00000002) move                 v1, v4

a-BB@0x4 : [ a-BB@0xc a-BB@0x22 ]
	2       (00000004) add-int              v2, v4, v5
	3       (00000008) if-ge                v1, v2, +d

a-BB@0xc : [ a-BB@0x18 a-BB@0x1c ]
	4       (0000000c) shl-int/lit8         v0, v0, 1
	5       (00000010) aget-boolean         v2, v3, v1
	6       (00000014) if-eqz               v2, +4

a-BB@0x18 : [ a-BB@0x1c ]
	7       (00000018) or-int/lit8          v0, v0, 1

a-BB@0x1c : [ a-BB@0x4 ]
	8       (0000001c) add-int/lit8         v1, v1, 1
	9       (00000020) goto                 -e

a-BB@0x22 : 
