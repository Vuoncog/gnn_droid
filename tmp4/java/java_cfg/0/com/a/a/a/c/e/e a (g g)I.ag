# Lcom/a/a/a/c/e;->a(Lcom/a/a/a/c/g; Lcom/a/a/a/c/g;)I [access_flags=public]
#
# Parameters:
# - local registers: v0...v2
# - v3:com.a.a.a.c.g
# - v4:com.a.a.a.c.g
#
# - return:int

a-BB@0x0 : 
	0       (00000000) invoke-virtual       v3, Lcom/a/a/a/c/g;->c()I
	1       (00000006) move-result          v0
	2       (00000008) invoke-virtual       v4, Lcom/a/a/a/c/g;->c()I
	3       (0000000e) move-result          v1
	4       (00000010) sub-int/2addr        v0, v1
	5       (00000012) return               v0

