package com.isnowstudio.filemanager;

import java.io.BufferedReader;
import java.io.FileNotFoundException;
import java.io.FileReader;
import java.io.IOException;

import android.content.Intent;
import android.net.Uri;
import android.os.Bundle;
import android.os.Handler;
import android.os.Message;
import android.widget.TextView;

import com.isnowstudio.R;
import com.isnowstudio.common.IsnowActivity;

/**
 * 以文本方式查看文件内容的activity
 * 暂废弃，由HTMLViewer（来自android源代码）代替，
 * 
 * @author evan
 *
 */
public class TextViewerActivity extends IsnowActivity {

	private TextView mTextView;
    private Uri mUri;
	
	public static final int SHOW_DATA = 0;
	
	public Handler mHandler = new Handler() {
		@Override
		public void handleMessage(Message msg) {
			switch(msg.what) {
			case SHOW_DATA:
				mTextView.append((String)msg.obj);
				
				break;
			}


		}
	};

	/* (non-Javadoc)
	 * @see android.app.Activity#onCreate(android.os.Bundle)
	 */
	@Override
	protected void onCreate(Bundle savedInstanceState) {

		this.setContentView(R.layout.text_viewer);
		
		initToolTitleBar();
		
		mTextView = (TextView)findViewById(R.id.text);
		
        final Intent intent = getIntent();
        final String action = intent.getAction();
        if (Intent.ACTION_VIEW.equals(action)) {
            mUri = intent.getData();
            
            new Thread(new Runnable() {

				@Override
				public void run() {
					loadFileContent();
					
				}
            	
            }).start();
        }
        
		
		super.onCreate(savedInstanceState);
	}

	private void loadFileContent() {
		StringBuffer textBuffer = new StringBuffer();
		
		BufferedReader buffer = null;
		try {
			buffer = new BufferedReader(new FileReader(mUri.getPath()));
			String lineText = buffer.readLine();
			while (null != lineText) {
				
				textBuffer.append(lineText);
				
				if (textBuffer.length()>4*1024) {
					Message msg = mHandler.obtainMessage(SHOW_DATA, textBuffer.toString());
					mHandler.sendMessage(msg);
					
					textBuffer = new StringBuffer();
				}
				
				//textBuffer.append(mReadText);
				lineText = buffer.readLine();
			}
			
			Message msg = mHandler.obtainMessage(SHOW_DATA, textBuffer.toString());
			mHandler.sendMessage(msg);

			buffer.close();
		} catch (FileNotFoundException e) {
		} catch (IOException e) {
		} finally {
			if (buffer != null)
				try {
					buffer.close();
				} catch (IOException e) {
				}
		}

		//mTextView.setText(textBuffer);
	}

}
