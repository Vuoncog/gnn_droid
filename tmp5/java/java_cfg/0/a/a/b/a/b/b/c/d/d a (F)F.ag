# La/a/b/a/b/b/c/d;->a(F)F [access_flags=public final]
#
# Parameters:
# - local registers: v0...v2
# - v3:float
#
# - return:float

a-BB@0x0 : 
	0       (00000000) iget                 v0, v2, La/a/b/a/b/b/c/d;->c F
	1       (00000004) sub-float            v0, v3, v0
	2       (00000008) iget                 v1, v2, La/a/b/a/b/b/c/d;->d F
	3       (0000000c) div-float/2addr      v0, v1
	4       (0000000e) return               v0

