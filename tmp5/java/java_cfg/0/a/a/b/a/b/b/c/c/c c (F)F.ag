# La/a/b/a/b/b/c/c;->c(F)F [access_flags=public]
#
# Parameters:
# - local registers: v0...v1
# - v2:float
#
# - return:float

c-BB@0x0 : 
	0       (00000000) iget                 v0, v1, La/a/b/a/b/b/c/c;->c F
	1       (00000004) div-float            v0, v2, v0
	2       (00000008) return               v0

